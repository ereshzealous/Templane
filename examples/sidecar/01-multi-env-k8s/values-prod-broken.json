{
  "environment": "production",
  "namespace": "templane",
  "replicas": "many",
  "image": {
    "repository": "acme/templane",
    "tag": "v0.1.0",
    "pull_policy": "always"
  },
  "service": { "tier": "backend", "port": "8080" },
  "rollout": { "strategy": "BlueGreen" },
  "resources": {
    "requests": { "cpu": "500m",  "memory": "512Mi" }
  },
  "env_vars": [
    { "name": "LOG_LEVEL", "value": "warn" }
  ],
  "probes": {
    "liveness":  { "path": "/healthz", "initial_delay_seconds": 30, "period_seconds": 15 },
    "readiness": { "path": "/ready",   "initial_delay_seconds": 15, "period_seconds": 10 }
  }
}
